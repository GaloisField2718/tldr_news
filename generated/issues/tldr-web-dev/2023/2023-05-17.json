          "reading_time_minutes": null,
          "source_domain": "github.com",
          "content_type": "github_repo",
          "is_sponsor": false
        },
        {
          "id": "tldr-web-dev:2023-05-17:o008",
          "order": 2,
          "title": "KNIP",
          "summary": "Knip finds unused files, dependencies and exports in your JavaScript and TypeScript projects. Less code and dependencies lead to improved performance, less maintenance and easier refactorings. Knip has good defaults and you can run it without any configuration.",
          "url": "https://github.com/webpro/knip",
          "reading_time_minutes": null,
          "source_domain": "github.com",
          "content_type": "github_repo",
          "is_sponsor": false
