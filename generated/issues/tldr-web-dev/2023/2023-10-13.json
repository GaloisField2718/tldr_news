          "reading_time_minutes": null,
          "source_domain": "oort.rs",
          "content_type": "tool",
          "is_sponsor": false
        },
        {
          "id": "tldr-web-dev:2023-10-13:o009",
          "order": 3,
          "title": "SCALAR",
          "summary": "Scalar generates interactive API documentation from Swagger files, offering a live demo for users to try. It supports Swagger/OpenAPI specification files, provides request examples for various programming languages and frameworks, includes an integrated API client, and allows users to edit Swagger files with a live preview.",
