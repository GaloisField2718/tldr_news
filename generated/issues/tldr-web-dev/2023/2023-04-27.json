      "articles": [
        {
          "id": "tldr-web-dev:2023-04-27:o007",
          "order": 1,
          "title": "NANGO",
          "summary": "Nango is a service that simplifies OAuth implementation by containing everything you need to work with APIs that use OAuth. It contains a full OAuth dance for 90+ APIs, a frontend SDK to trigger new OAuth flows, a backend SDK and REST API to retrieve fresh access tokens for your API calls, and lastly, a proxy to both authenticate and perform authenticated requests to an API.",
          "url": "https://github.com/nangoHQ/nango",
          "reading_time_minutes": null,
          "source_domain": "github.com",
          "content_type": "github_repo",
          "is_sponsor": false
        },
        {
          "id": "tldr-web-dev:2023-04-27:o008",
          "order": 2,
          "title": "PYTHAGORA",
          "summary": "Pythagora lets developers generate integration tests for their Node.js apps by recording server activity without writing a single line of code.",
          "url": "https://github.com/Pythagora-io/pythagora",
          "reading_time_minutes": null,
          "source_domain": "github.com",
          "content_type": "github_repo",
          "is_sponsor": false
        },
        {
          "id": "tldr-web-dev:2023-04-27:o009",
          "order": 3,
          "title": "TUQL",
          "summary": "Tuql is a simple tool that turns a formatted SQLite database into a GraphQL endpoint. It tries to infer relationships between objects, currently supporting belongsTo, hasMany and belongsToMany. It also forms the basic mutations necessary to create, update, and delete objects, as well as associate many-to-many relationships.",
          "url": "https://github.com/bradleyboy/tuql",
          "reading_time_minutes": null,
          "source_domain": "github.com",
          "content_type": "github_repo",
          "is_sponsor": false
        }
