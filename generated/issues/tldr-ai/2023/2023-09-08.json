          "id": "tldr-ai:2023-09-08:o005",
          "order": 1,
          "title": "DIFFUSION",
          "summary": "Neural fields use a multilayer perceptron (MLP) to represent a 3D scene. It turns out you can apply diffusion directly to the weights of the MLP and generate a novel 3D scene.",
          "url": "https://ziyaerkoc.com/hyperdiffusion/?utm_source=tldrai",
          "reading_time_minutes": 28,
          "source_domain": "ziyaerkoc.com",
          "content_type": "editorial",
          "is_sponsor": false
        },
        {
          "id": "tldr-ai:2023-09-08:o006",
          "order": 2,
          "title": "ONE WIDE FEEDFORWARD IS ALL YOU NEED",
          "summary": "The feedforward layers of the transformer make up a significant portion of the total weights in the network. However, if you use a single large feedforward layer shared between the encoder and decoder, you can dramatically improve inference time with minimal drops in performance.",
          "url": "https://arxiv.org/abs/2309.01826?utm_source=tldrai",
          "reading_time_minutes": 18,
          "source_domain": "arxiv.org",
          "content_type": "editorial",
          "is_sponsor": false
        },
        {
          "id": "tldr-ai:2023-09-08:o007",
          "order": 3,
          "title": "USING LLMS TO PREDICT STOCK TRENDS",
          "summary": "This paper introduces a way to use large language models to quickly analyze long Annual Reports from companies, making it easier to understand their financial health and even predict stock prices.",
          "url": "https://arxiv.org/abs/2309.03079v1?utm_source=tldrai",
          "reading_time_minutes": 26,
          "source_domain": "arxiv.org",
